// Schéma Prisma — IT-Inventory
// Base de données PostgreSQL pour la gestion de stock informatique

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Rôles utilisateur
enum Role {
  ADMIN
  TECHNICIAN
}

// Types de mouvement de stock
enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  TRANSFER
}

// Utilisateur / Technicien IT
model User {
  id           String          @id @default(cuid())
  technicianId String          @unique
  name         String
  password     String
  role         Role            @default(TECHNICIAN)
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  siteId       String?
  site         Site?           @relation(fields: [siteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  movements    StockMovement[]
  auditLogs    AuditLog[]
}

// Site de stockage
model Site {
  id            String          @id @default(cuid())
  name          String          @unique
  address       String?
  parentSiteId  String?
  edsNumber     String?
  parent        Site?           @relation("SiteChildren", fields: [parentSiteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children      Site[]          @relation("SiteChildren")
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  stocks        ArticleStock[]
  movementsFrom StockMovement[] @relation("fromSite")
  movementsTo   StockMovement[] @relation("toSite")
  users         User[]
}

// Article du stock informatique
model Article {
  id          String          @id @default(cuid())
  reference   String          @unique
  name        String
  description String?
  category    String
  codeFamille String?
  articleType String?
  sousType    String?
  emplacement String?
  brand       String?
  model       String?
  barcode     String?         @unique
  imageUrl    String?
  unit        String          @default("pièce")
  minStock    Int             @default(0)
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stocks      ArticleStock[]
  movements   StockMovement[]
  auditLogs   AuditLog[]
}

// Stock d'un article sur un site
model ArticleStock {
  id        String  @id @default(cuid())
  articleId String
  siteId    String
  quantity  Int     @default(0)
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site      Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([articleId, siteId])
}

// Mouvement de stock
model StockMovement {
  id         String       @id @default(cuid())
  type       MovementType
  quantity   Int
  reason     String?
  articleId  String
  fromSiteId String?
  toSiteId   String?
  userId     String
  createdAt  DateTime     @default(now())
  article    Article      @relation(fields: [articleId], references: [id])
  fromSite   Site?        @relation("fromSite", fields: [fromSiteId], references: [id])
  toSite     Site?        @relation("toSite", fields: [toSiteId], references: [id])
  user       User         @relation(fields: [userId], references: [id])
}

// Journal d'audit
model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  userId     String
  articleId  String?
  createdAt  DateTime @default(now())
  article    Article? @relation(fields: [articleId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

// Configuration de l'application
model AppConfig {
  key       String    @id
  value     String
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
}
